{
  "name": "slopcost",
  "displayName": "slopcost",
  "description": "AI cost analytics & explanations",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiCost.configureApiKey",
        "title": "AI Cost: Configure API Key"
      },
      {
        "command": "aiCost.showTodayCost",
        "title": "AI Cost: Show Today's Cost"
      },
      {
        "command": "aiCost.explainTodayCost",
        "title": "AI Cost: Explain Today's Cost"
      },
      {
        "command": "aiCost.configureAvailableModels",
        "title": "AI Cost: Configure Available Models"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}